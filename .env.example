# MongoDB Atlas connection string. Special characters in the password
# (e.g. '@') must be URL-encoded ('@' -> '%40').
MONGO_URI=mongodb+srv://<user>:<url-encoded-password>@<cluster>.mongodb.net/?appName=<app>
MONGO_DB_NAME=NutSoul

# Secrets used by Flask + JWT. Generate with:  python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET_KEY=

# Comma-separated allowed origins for CORS. Use "*" only for testing.
# Example: https://nutsoul-fe.vercel.app
CORS_ORIGINS=*
